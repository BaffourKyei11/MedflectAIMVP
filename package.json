{
  "name": "medflect-ai-mvp",
  "version": "1.0.0",
  "description": "Medflect AI - Healthcare PWA with Groq LLM integration and FHIR R4 compliance",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "bootstrap": "npm install && npm run build:all",
    "dev:web": "npm run dev --workspace=@medflect/web",
    "build:web": "npm run build --workspace=@medflect/web",
    "build:all": "npm run build --workspaces",
    "start:local": "docker-compose up --build",
    "demo": "bash scripts/demo.sh",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "type-check": "npm run type-check --workspaces",
    "clean": "npm run clean --workspaces",
    "dev:server": "npm run dev --workspace=@medflect/server",
    "dev:mobile": "npm run dev --workspace=@medflect/mobile"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "prettier": "^3.0.0",
    "eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
} 