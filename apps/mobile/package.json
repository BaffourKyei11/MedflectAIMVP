    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@supabase/supabase-js": "^2.38.4",
    "react-native-async-storage": "^1.21.0",
    "react-native-vector-icons": "^10.0.3",
    "react-native-paper": "^5.11.4",
    "react-native-elements": "^3.4.3",
    "react-native-gesture-handler": "~2.14.0",
    "react-native-reanimated": "~3.6.0",
    "react-native-svg": "14.1.0",
    "react-native-chart-kit": "^6.12.0",
    "react-native-qrcode-scanner": "^1.5.5",
    "react-native-permissions": "^4.0.0",
    "react-native-camera": "^4.2.1",
    "react-native-push-notification": "^8.1.1",
    "react-native-background-job": "^2.2.0",
    "react-native-offline": "^6.0.0",
    "react-native-netinfo": "^11.2.1",
    "react-native-splash-screen": "^3.3.0",
    "react-native-keychain": "^8.1.2",
    "react-native-biometrics": "^3.0.1",
    "react-native-localize": "^3.0.4",
    "react-native-i18n": "^2.0.15",
    "react-native-config": "^1.5.1",
    "react-native-dotenv": "^3.4.9",
    "react-native-version-check": "^3.4.2",
    "react-native-device-info": "^10.11.0",
    "react-native-sentry": "^5.5.0",
    "react-native-fabric": "^0.5.1",
    "react-native-crashlytics": "^3.3.1",
    "react-native-firebase": "^18.7.3",
    "react-native-google-signin": "^10.1.1",
    "react-native-apple-authentication": "^2.0.0",
    "react-native-facebook-login": "^1.0.0",
    "react-native-twitter-signin": "^1.0.0",
    "react-native-linkedin-login": "^1.0.0",
    "react-native-microsoft-login": "^1.0.0",
    "react-native-google-maps": "^1.7.1",
    "react-native-maps": "1.7.1",
    "react-native-geolocation-service": "^5.3.1",
    "react-native-geocoding": "^0.5.0",
    "react-native-google-places-autocomplete": "^2.5.6",
    "react-native-image-picker": "^7.1.0",
    "react-native-image-crop-picker": "^0.40.2",
    "react-native-image-resizer": "^1.4.5",
    "react-native-fast-image": "^8.6.3",
    "react-native-video": "^5.2.1",
    "react-native-audio": "^4.3.0",
    "react-native-sound": "^0.11.2",
    "react-native-voice": "^3.2.4",
    "react-native-speech": "^0.1.0",
    "react-native-tts": "^4.1.0",
    "react-native-ble-plx": "^3.0.2",
    "react-native-ble-manager": "^10.1.2",
    "react-native-nfc-manager": "^3.14.12",
